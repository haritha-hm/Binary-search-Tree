 public static void level(Node root){
      Queue <Node>q=new LinkedList<>();
       q.offer(root);
      while(!q.isEmpty()){
        Node t=q.poll();
      System.out.print(t.data+" ");
        if(t.left!=null)
        q.offer(t.left);
        if(t.right!=null)
        q.offer(t.right);
      }
    }
